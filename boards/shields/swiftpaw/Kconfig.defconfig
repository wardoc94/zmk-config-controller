if SHIELD_SWIFTPAW_LEFT

config ZMK_KEYBOARD_NAME
    default "SwiftPaw"

config ZMK_SPLIT_ROLE_CENTRAL
    default y

endif # SHIELD_SWIFTPAW_LEFT

if SHIELD_SWIFTPAW_RIGHT

config ZMK_KEYBOARD_NAME
    default "SwiftPaw"

endif # SHIELD_SWIFTPAW_RIGHT

if SHIELD_SWIFTPAW_LEFT || SHIELD_SWIFTPAW_RIGHT

config ZMK_SPLIT
    default y

endif # SHIELD_SWIFTPAW_LEFT || SHIELD_SWIFTPAW_RIGHT

if SHIELD_SWIFTPAW_RIGHT_STANDALONE

config ZMK_KEYBOARD_NAME
    default "SwiftPaw Solo"

# Deliberately no ZMK_SPLIT default here - this shield is a full standalone
# keyboard by itself for testing the right half (matrix + PAW3395) without
# needing the left half paired.

endif # SHIELD_SWIFTPAW_RIGHT_STANDALONE
